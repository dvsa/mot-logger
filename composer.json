{
    "name": "dvsa/mot-logger",
    "description": "Unified logging utility for DVSA MOT applications, powered by Monolog.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "logging",
        "monolog",
        "dvsa",
        "mot"
    ],
    "require": {
        "php": "^8.2",
        "doctrine/dbal": "^3.5 || ^4.0",
        "ext-json": "*",
        "monolog/monolog": "^3.10",
        "laminas/laminas-eventmanager": "^3.15",
        "laminas/laminas-mvc": "^3.8",
        "laminas/laminas-router": "^3.7",
        "laminas/laminas-modulemanager": "^2.16"
    },
    "require-dev": {
        "amphp/amp": "^2.6.5",
        "captainhook/captainhook": "^5.16",
        "captainhook/plugin-composer": "^5.3",
        "dvsa/coding-standards": "^2.0",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.10",
        "vimeo/psalm": "^5.24"
    },
    "autoload": {
        "psr-4": {
            "DvsaLogger\\": "src/"
        },
        "classmap": [
            "./Module.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "DvsaLogger\\Util\\": "tests/Util/",
            "DvsaCommon\\": "tests/Stubs/DvsaCommon/",
            "DvsaLoggerTest\\Unit\\": "tests/Unit/",
            "Psr\\Container\\": "tests/Stubs/Psr/Container/"
        }
    },
    "scripts": {
        "phpcs": "./vendor/bin/phpcs .",
        "phpcs:fix": "./vendor/bin/phpcbf .",
        "phpstan": "./vendor/bin/phpstan",
        "psalm": "./vendor/bin/psalm",
        "test": "vendor/bin/phpunit -c phpunit.xml",
        "test:coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit -c phpunit.xml --coverage-html coverage"
    },
    "config": {
        "allow-plugins": {
            "captainhook/plugin-composer": true,
            "laminas/laminas-dependency-plugin": true
        }
    }
}
